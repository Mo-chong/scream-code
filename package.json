{
  "name": "scream-code-monorepo",
  "version": "0.7.2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:dev": "bash scripts/build-dev.sh",
    "build:packages": "pnpm -r --filter './packages/*' run build",
    "dev:cli": "pnpm -C apps/scream-code run dev",
    "typecheck": "pnpm run build:packages && pnpm -r --filter './packages/*' run typecheck && pnpm --filter scream-code run typecheck",
    "lint": "oxlint --type-aware",
    "lint:fix": "pnpm run lint --fix",
    "lint:pkg": "pnpm -r --filter '!scream-code-monorepo' exec publint && pnpm -r --filter './packages/*' exec attw --pack . --profile node16 --ignore-rules cjs-resolves-to-esm internal-resolution-error",
    "sherif": "sherif",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "version": "changeset version",
    "version:release": "changeset version",
    "publish": "pnpm run typecheck && pnpm run lint && pnpm run sherif && pnpm run test && pnpm run build && pnpm run lint:pkg && changeset publish",
    "prepare": "node scripts/prepare.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.30.0",
    "@microsoft/api-extractor": "7.58.7",
    "@photostructure/sqlite-vec": "^1.1.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "4.1.4",
    "fastembed": "^2.1.0",
    "lint-staged": "16.4.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "pkg-pr-new": "0.0.75",
    "publint": "0.3.18",
    "sherif": "1.11.1",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "./scripts/guards/check-all.sh --quiet"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "onnxruntime-node"
    ],
    "patchedDependencies": {
      "@earendil-works/pi-tui@0.78.1": "patches/@earendil-works__pi-tui@0.78.1.patch"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxlint --fix --quiet",
      "oxlint --type-aware --quiet"
    ]
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
